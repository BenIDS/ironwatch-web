# ── IRONWATCH Server Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

# Your Anthropic API key from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE-WITH-YOUR-KEY

# Team password to access IRONWATCH (change this!)
APP_PASSWORD=ironwatch2024

# Your Vercel frontend URL (set after deploying frontend)
FRONTEND_URL=https://ironwatch.vercel.app

# Port (Render sets this automatically, leave as 3001 for local dev)
PORT=3001
